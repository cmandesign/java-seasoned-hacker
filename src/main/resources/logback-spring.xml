<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- A09 demo: dedicated security audit log with structured format -->
    <appender name="SECURITY_AUDIT" class="ch.qos.logback.core.FileAppender">
        <file>logs/security-audit.log</file>
        <encoder>
            <pattern>%d{ISO8601} | %X{action} | %X{userId} | %X{sourceIp} | %X{outcome} | %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JSON activity log for filebeat/ELK ingestion -->
    <appender name="ACTIVITY_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>myapp/activity.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>myapp/activity-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>@timestamp</fieldName>
                </timestamp>
                <mdc/>
                <message>
                    <fieldName>message</fieldName>
                </message>
            </providers>
        </encoder>
    </appender>

    <logger name="com.owaspdemo.a09_logging_failures.secure" level="INFO" additivity="false">
        <appender-ref ref="SECURITY_AUDIT"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="activity.log" level="INFO" additivity="false">
        <appender-ref ref="ACTIVITY_JSON"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
